# Moodle Webservice API, used by import/status/ping commands.
MOODLE_BASE_URL=https://www.example-moodle.test
MOODLE_TOKEN=replace-with-your-webservice-token

# Optional global Playwright upload defaults.
# Course-specific values below override these.
MOODLE_COURSE_URL=https://www.example-moodle.test/course/view.php?id=1
MOODLE_USERNAME=replace-with-your-login
MOODLE_PASSWORD=replace-with-your-password

# Course-specific Playwright upload settings.
# Pattern: MOODLE_<COURSE_FOLDER>_<SETTING>
# Convert the course folder to uppercase and replace non-alphanumeric
# characters such as "-" with "_".
MOODLE_PYTHON_2026_COURSE_URL=https://www.opencoding.de/course/view.php?id=5
MOODLE_PYTHON_2026_USERNAME=replace-with-python-course-login
MOODLE_PYTHON_2026_PASSWORD=replace-with-python-course-password

# Additional targets for the same local course.
# Use with: invoke upload-chapter-moodle 013-texte-strings --course=python-2026 --target=2
MOODLE_PYTHON_2026_2_COURSE_URL=https://www.second-moodle.test/course/view.php?id=9
MOODLE_PYTHON_2026_2_USERNAME=replace-with-2-site-login
MOODLE_PYTHON_2026_2_PASSWORD=replace-with-2-site-password
# Optional; otherwise courses/python-2026/.moodle-storage-state-2.json is used.
MOODLE_PYTHON_2026_2_STORAGE_STATE=courses/python-2026/.moodle-storage-state-2.json

# Example for another local course folder named "info-2026".
MOODLE_INFO_2026_COURSE_URL=https://www.example-moodle.test/course/view.php?id=12
MOODLE_INFO_2026_USERNAME=replace-with-info-course-login
MOODLE_INFO_2026_PASSWORD=replace-with-info-course-password
